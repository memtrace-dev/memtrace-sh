---
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border-color transition-colors duration-200">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <img src="/logo.svg" alt="memtrace" class="h-7 w-auto" />
    <div class="flex items-center gap-4 sm:gap-6 text-sm font-medium">
      <a href="https://github.com/memtrace-dev/memtrace/blob/main/README.md" target="_blank" class="text-muted hover:text-primary transition-colors hidden sm:block">Docs</a>
      <a href="https://github.com/memtrace-dev/memtrace" target="_blank" class="text-muted hover:text-primary transition-colors hidden sm:block">GitHub</a>
      <button
        id="theme-toggle"
        class="text-muted hover:text-primary transition-colors p-2 rounded-full hover:bg-surface cursor-pointer"
        aria-label="Toggle theme"
      >
        <!-- Sun: shown in dark mode -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
        </svg>
        <!-- Moon: shown in light mode -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>
      <a href="#install" class="px-4 py-1.5 rounded-full bg-surface border border-border-color text-primary hover:bg-border-color transition-colors hidden sm:block">
        Install &rarr;
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('theme-toggle');
  const sunIcon = document.getElementById('icon-sun');
  const moonIcon = document.getElementById('icon-moon');

  function syncIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    sunIcon?.classList.toggle('hidden', !isDark);
    moonIcon?.classList.toggle('hidden', isDark);
  }

  syncIcons();

  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    document.documentElement.classList.toggle('dark', !isDark);
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
    syncIcons();
  });
</script>
