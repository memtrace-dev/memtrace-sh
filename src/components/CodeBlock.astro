---
interface Props {
  code: string;
  language?: string;
}
const { code, language = 'bash' } = Astro.props;
---
<div class="group relative bg-surface border border-border-color rounded-lg overflow-hidden">
  <div class="absolute inset-0 pointer-events-none rounded-lg shadow-[inset_0_1px_0_0_var(--color-shadow-inner)]"></div>
  <div class="flex justify-between items-center px-4 py-2 border-b border-border-color bg-surface/50">
    <span class="text-xs font-mono text-muted">{language}</span>
    <button data-copy={code} class="copy-btn text-muted hover:text-primary transition-colors">
      <svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      <svg class="icon-check hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 6 9 17l-5-5"/>
      </svg>
    </button>
  </div>
  <div class="p-4 overflow-x-auto text-sm font-mono text-primary whitespace-pre flex">
    <span class="text-muted select-none mr-4">$</span>
    <span>{code}</span>
  </div>
</div>
